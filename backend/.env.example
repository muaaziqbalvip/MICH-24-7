# MiTV Backend Environment Variables
# Copy this file to .env and fill in your values

PORT=3000

# Firebase Admin SDK (get from Firebase Console → Project Settings → Service Accounts → Generate new private key)
FB_PRIVATE_KEY_ID=your_private_key_id_here
FB_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n"
FB_CLIENT_EMAIL=firebase-adminsdk-xxxxx@ramadan-2385b.iam.gserviceaccount.com
FB_CLIENT_ID=your_client_id_here

# Optional: ImgBB key (already hardcoded in frontend, but can override)
IMGBB_KEY=6bdb23b28e7581721b28e46ce313308b
